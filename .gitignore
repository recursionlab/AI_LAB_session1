__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/
.python-version

# Jupyter Notebooks
.ipynb_checkpoints
*/.ipynb_checkpoints/*

# Temporary files
*.tmp
*.temp
*.log
