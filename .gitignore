*.swo
*~

# IDE files
.vscode/
.idea/
*.sublime-*
.atom/
*.atom

# Build outputs
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Archive files
*.zip
*.tar.gz
*.rar
*.7z

# Sensitive files (if added later)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
config/secrets.yml

# Backup files
*.backup
*.bak
*.orig

# Large files that shouldn't be in Git
*.mp4
*.avi
*.mov
*.wmv
*.flv
*.wav
*.mp3
*.zip
*.tar
*.dmg

# Meta-Structural Telo-Filter: Ultra-Strict Core-Only (Minimize Context Bloat)
# Default shadow everything
*

# Telic Core: Runtime App
!src/
!public/
!package.json
!pnpm-lock.yaml
!next.config.ts
!tailwind.config.ts
!tsconfig.json
!postcss.config.mjs
!components.json
!.eslintrc.json
!.gitignore

# Meta-Ops Root Essentials
!README.md
!SUMMARY.md
!TODO.md
!LICENSE
!AI_RULES.md
!manifesto_readme.md
!THIS_WILL_ORIENT_YOU.md

# Spectral Overrides: Keep runtime assets, shadow bulk UI
!public/*.svg
src/components/ui/     # Shadow shadcn bulk
!src/components/avatar/**

# Periphery Complete Shadow
notebooks/
sandbox/
user_workspace/
*.md
*.log
*.tmp
